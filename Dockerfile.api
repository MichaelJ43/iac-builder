# syntax=docker/dockerfile:1
FROM golang:1.22-bookworm AS build
WORKDIR /src
COPY src/api/go.mod src/api/go.sum ./
RUN GOSUMDB=off go mod download
COPY src/api/ ./
ARG APP_VERSION=0.0.0
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/iac-builder-api ./cmd/iac-builder-api

FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /
COPY --from=build /out/iac-builder-api /iac-builder-api
USER nonroot:nonroot
ENV LISTEN_ADDR=:8080
EXPOSE 8080
ENTRYPOINT ["/iac-builder-api"]

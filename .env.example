# 64 hex characters (32 bytes) — required for encrypted credential profiles
IAC_MASTER_KEY=

# Optional — defaults shown in docker-compose.yml
APP_VERSION=0.1.0
CORS_ORIGIN=*

# Vite (src/ui) — set to "true" at *build* time to show optional AI assist policy panel (no LLM in default app)
# VITE_IAC_AI_ASSIST=true

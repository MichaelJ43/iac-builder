# 64 hex characters (32 bytes) — required for encrypted credential profiles
IAC_MASTER_KEY=

# Optional — defaults shown in docker-compose.yml
APP_VERSION=0.1.0
CORS_ORIGIN=*

# Vite (src/ui) — set to "true" at *build* time to show optional AI assist policy panel
# VITE_IAC_AI_ASSIST=true

# API — max POST /api/v1/ai/assist calls per client IP per wall-clock minute (default 20)
# IAC_AI_ASSIST_RPM=20
# When users save an OpenAI key (BYOK), chat completion model and optional API base
# IAC_OPENAI_MODEL=gpt-4o-mini
# IAC_OPENAI_BASE_URL=https://api.openai.com
#
# API — operator preview guardrails (optional; 1/true/yes/on). Unset in local dev if they block you.
# IAC_BLOCK_SSH_OPEN_WORLD=1
# IAC_REQUIRE_IMDSV2=1
# IAC_REQUIRE_EBS_ENCRYPTION=1
# IAC_BLOCK_ASSOCIATE_PUBLIC_IP=1
